#!/bin/bash

# Base script generated by NERSC Batch Script Generator on https://iris.nersc.gov/jobscript.html

#SBATCH -N 2
#SBATCH -C cpu
# SBATCH -G 1
#SBATCH -q debug
#SBATCH -J series2
#SBATCH -A m5128
#SBATCH -t 0:30:0
#SBATCH --output=series_2cores.%j.out
#SBATCH --mail-user=kbilal@lbl.gov
#SBATCH --mail-type=BEGIN,END,FAIL


# OpenMP settings:
export OMP_NUM_THREADS=1
export OMP_PLACES=threads
export OMP_PROC_BIND=spread

#run the application: 
# applications may perform better with --gpu-bind=none instead of --gpu-bind=single:1
srun -n 1 -c 256 --cpu_bind=cores -G 1 --gpu-bind=single:1 podman-hpc run --userns=keep-id --rm --gpu -v "$PWD":/workspace --entrypoint="/workspace/scripts/entrypoint_batch.sh" working
