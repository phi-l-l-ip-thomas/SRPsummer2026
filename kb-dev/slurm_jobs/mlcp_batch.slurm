#!/bin/bash

# Base script generated by NERSC Batch Script Generator on https://iris.nersc.gov/jobscript.html

#SBATCH -N 1
#SBATCH -C gpu
#SBATCH -G 1
#SBATCH -q regular
#SBATCH -J mlcp_gpu_test
#SBATCH -A m5128
#SBATCH -t 5:00:0
#SBATCH --mail-user=kbilal@lbl.gov
#SBATCH --mail-type=BEGIN


# OpenMP settings:
export OMP_NUM_THREADS=1
export OMP_PLACES=threads
export OMP_PROC_BIND=spread

#run the application: 
# applications may perform better with --gpu-bind=none instead of --gpu-bind=single:1
srun -n 1 -c 128 --cpu_bind=cores -G 1 --gpu-bind=single:1 podman-hpc run --rm --gpu -v "$PWD":/workspace --entrypoint="/workspace/scripts/entrypoint_batch.sh" working
